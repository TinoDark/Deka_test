# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL="postgresql://dekora:password123@localhost:5432/dekora_social_commerce"

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# ============================================================================
# JWT & AUTH
# ============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION=900  # 15 minutes in seconds
JWT_REFRESH_EXPIRATION=604800  # 7 days

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_PORT=3000
API_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================================================
# FRONTEND URLS
# ============================================================================
FRONTEND_CLIENT_URL="http://localhost:3001"
FRONTEND_RESELLER_URL="http://localhost:3002"
FRONTEND_SUPPLIER_URL="http://localhost:3003"
FRONTEND_ADMIN_URL="http://localhost:3004"

# ============================================================================
# MOBILE MONEY PROVIDERS
# ============================================================================
# MTN
MTN_API_KEY="your-mtn-api-key"
MTN_API_URL="https://sandbox.momodeveloper.mtn.com"

# ORANGE
ORANGE_API_KEY="your-orange-api-key"
ORANGE_API_URL="https://staging-api.orange.com"

# WAVE
WAVE_API_KEY="your-wave-api-key"
WAVE_API_URL="https://api.sandbox.wave.com"

PAYMENT_WEBHOOK_SECRET="webhook-secret-key"

# ============================================================================
# STORAGE (S3 / MinIO)
# ============================================================================
AWS_REGION="us-east-1"
AWS_S3_BUCKET="dekora-products"
AWS_S3_URL="https://s3.amazonaws.com"
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"

# MinIO (alternative)
MINIO_ENDPOINT="minio"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="dekora"

# ============================================================================
# SMS & NOTIFICATIONS
# ============================================================================
SMS_PROVIDER="twilio"  # twilio, africastalking, etc.
SMS_API_KEY="your-sms-api-key"
SMS_FROM_NUMBER="+1234567890"

# ============================================================================
# KYC & COMPLIANCE
# ============================================================================
KYC_PROVIDER="jumio"  # or other KYC provider
KYC_API_KEY="your-kyc-api-key"

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN="https://your-sentry-dsn/"
LOG_LEVEL="debug"

# ============================================================================
# SECURITY
# ============================================================================
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004"
RATE_LIMIT_TTL=900  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
